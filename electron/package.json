{
  "name": "floating-agent-electron",
  "version": "0.1.0",
  "description": "Floating Agent — Electron main process",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "dev": "tsc --watch & electron .",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "package": "electron-builder",
    "package:linux": "electron-builder --linux",
    "package:win": "electron-builder --win"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^41.3.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.2.1"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  },
  "build": {
    "appId": "io.chrysa.floating-agent",
    "productName": "Floating Agent",
    "directories": {
      "output": "out"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    },
    "win": {
      "target": ["nsis"]
    },
    "extraResources": [
      {
        "from": "../daemon",
        "to": "daemon"
      }
    ]
  }
}
